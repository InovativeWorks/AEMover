<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="11.0"
                   ExtensionBundleId="AEMover"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="AE Mover">

  <ExtensionList>
    <Extension Id="AEMover.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="AEMover.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/hostscript.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <CSPolicy>
          <![CDATA[script-src 'self' 'unsafe-inline' 'unsafe-eval'; object-src 'self']]>
        </CSPolicy>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AE Mover</Menu>
          <Geometry>
            <Size>
              <Width>300</Width>
              <Height>500</Height>
            </Size>
            <MinSize>
              <Width>300</Width>
              <Height>500</Height>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
